{
  "manifest_version": 3,
  "name": "Bili 投资研究总结",
  "version": "1.0",
  "description": "一键生成 B站视频的投资研究总结，存入本地知识库",
  "permissions": ["storage"],
  "host_permissions": ["https://www.bilibili.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.bilibili.com/video/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
